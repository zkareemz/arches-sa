---
import type { SiteContent } from "../../../data/content";

import Reveal from "../../../ui/Reveal.astro";
import SectionHeader from "../../../ui/SectionHeader.astro";

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { who } = content;
---

<section id="about" class:list={["bg-quill-gray-50", "text-ink-900"]}>
  <div
    class:list={[
      "mx-auto",
      "w-full",
      "max-w-6xl",
      "px-6",
      "py-24",
      "sm:px-10",
      "sm:py-32",
    ]}
  >
    <Reveal>
      <SectionHeader
        eyebrow={who.eyebrow}
        title={who.title}
        intro={who.intro}
        align="center"
        class:list={["mx-auto"]}
      />
    </Reveal>

    <div
      class:list={[
        "mt-16",
        "grid",
        "grid-cols-1",
        "gap-10",
        "sm:mt-20",
        "md:grid-cols-3",
        "md:gap-8",
      ]}
    >
      {
        who.points.map((point, i) => (
          <Reveal
            delay={i * 100}
            class:list={[
              "flex",
              "flex-col",
              "gap-4",
              "border-t",
              "border-ink-900/12",
              "pt-6",
            ]}
          >
            <span class:list={["text-sm", "font-medium", "text-clay-600"]}>
              0{i + 1}
            </span>
            <h3 class:list={["text-xl", "font-light", "tracking-tight"]}>
              {point.title}
            </h3>
            <p class:list={["leading-relaxed", "text-ink-500"]}>{point.desc}</p>
          </Reveal>
        ))
      }
    </div>
  </div>
</section>
