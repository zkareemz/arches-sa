---
import type { SiteContent } from "../../../data/content";

import ContactDetails from "../../../ui/ContactDetails.astro";
import EnquiryForm from "../../../ui/EnquiryForm.astro";
import Eyebrow from "../../../ui/Eyebrow.astro";
import LocationMap from "../../../ui/LocationMap.astro";
import Reveal from "../../../ui/Reveal.astro";

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
const { contact } = content;
---

<section id="contact" class:list={["bg-ink-950", "text-quill-gray-50"]}>
  <div
    class:list={[
      "mx-auto",
      "w-full",
      "max-w-7xl",
      "px-6",
      "py-24",
      "sm:px-10",
      "sm:py-32",
    ]}
  >
    <Reveal class:list={["flex", "flex-col", "gap-5"]}>
      <Eyebrow text={contact.eyebrow} tone="light" bar />
      <h2
        class:list={[
          "max-w-3xl",
          "text-balance",
          "text-4xl",
          "font-light",
          "leading-[1.1]",
          "tracking-tight",
          "sm:text-5xl",
          "lg:text-6xl",
        ]}
      >
        {contact.title}
      </h2>
    </Reveal>

    <div
      class:list={[
        "mt-16",
        "grid",
        "grid-cols-1",
        "gap-14",
        "lg:grid-cols-12",
        "lg:gap-16",
      ]}
    >
      <Reveal class:list={["lg:col-span-7"]}>
        <EnquiryForm content={content} />
      </Reveal>

      <Reveal
        delay={120}
        class:list={[
          "flex",
          "flex-col",
          "gap-8",
          "lg:col-span-5",
          "lg:border-s",
          "lg:border-quill-gray-50/10",
          "lg:ps-16",
        ]}
      >
        <!-- <p class:list={["leading-relaxed", "text-quill-gray-300"]}>{contact.intro}</p> -->
        <ContactDetails content={content} />
      </Reveal>
    </div>

    <Reveal delay={80} class:list={["mt-14", "lg:mt-20"]}>
      <LocationMap content={content} />
    </Reveal>
  </div>
</section>
