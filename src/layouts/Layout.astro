---
import "../styles/global.css";

import Footer from "../components/Footer.astro";
import HeaderCentered from "../components/sections/header/HeaderCentered.astro";
import { getContent } from "../data/content";

interface Props {
  title?: string;
  description?: string;
}

const locale = Astro.currentLocale || "ar";
const content = getContent(locale);
const dir = content.dir;

const {
  title = locale === "en"
    ? "Arches | Architecture & Construction — Riyadh"
    : "أقواس | مكتب هندسي متعدد التخصصات — الرياض",
  description = content.hero.p,
} = Astro.props;
---

<!doctype html>
<html
  lang={locale}
  dir={dir}
  class:list={["flex", "flex-1", "flex-col", "min-h-svh"]}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.svg`} type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body
    class:list={[
      "flex",
      "flex-1",
      "flex-col",
      "min-h-svh",
      "bg-quill-gray-50",
      "font-sans",
      "text-ink-900",
      "antialiased",
    ]}
  >
    <HeaderCentered content={content} />
    <main class:list={["flex", "flex-1", "flex-col"]}>
      <slot />
    </main>
    <Footer content={content} />
    <script>
      import "../scripts/reveal.ts";
    </script>
  </body>
</html>
