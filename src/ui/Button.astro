---
import type { SvgComponent } from "astro/types";

interface Props {
  href?: string;
  label: string;
  variant?: "primary" | "outline" | "ghost";
  tone?: "dark" | "light";
  type?: "button" | "submit";
  class?: string;
  Icon?: SvgComponent & ImageMetadata;
  customIcon?: boolean;
}

const {
  href,
  label,
  variant = "primary",
  tone = "dark",
  type = "button",
  class: className,
  customIcon = false,
} = Astro.props;

const base = [
  "group",
  "inline-flex",
  "items-center",
  "justify-center",
  "gap-2.5",
  "rounded-md",
  "px-7",
  "py-3.5",
  "text-sm",
  "font-medium",
  "tracking-wide",
  "transition-colors",
  "duration-300",
  "focus-visible:outline-2",
  "focus-visible:outline-offset-2",
  "focus-visible:outline-clay-500",
];

const variants = {
  primary: "bg-clay-600 text-quill-gray-50 hover:bg-clay-700",
  outline:
    tone === "light"
      ? "border border-quill-gray-100/40 text-quill-gray-50 hover:border-quill-gray-50 hover:bg-quill-gray-50/5"
      : "border border-ink-900/25 text-ink-900 hover:border-ink-900/60 hover:bg-ink-900/5",
  ghost:
    tone === "light"
      ? "text-quill-gray-100 hover:text-quill-gray-50"
      : "text-ink-700 hover:text-clay-600",
};

const Tag = href ? "a" : "button";
---

<Tag
  href={href}
  type={href ? undefined : type}
  class:list={[base, variants[variant], className]}
>
  {customIcon ? <slot /> : undefined}
  {label}
  <span
    aria-hidden="true"
    class:list={[
      "transition-transform",
      "duration-300",
      "group-hover:translate-x-1",
      "rtl:group-hover:-translate-x-1",
      "rtl:-scale-x-100",
    ]}
  >
    &rarr;
  </span>
</Tag>
