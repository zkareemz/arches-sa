---
interface Props {
  text: string;
  tone?: "clay" | "light" | "muted";
  line?: boolean;
  bar?: boolean;
  class?: string;
}

const {
  text,
  tone = "clay",
  line = false,
  bar = false,
  class: className,
} = Astro.props;

const toneClass = {
  clay: "text-clay-600",
  light: "text-clay-300",
  muted: "text-ink-400",
}[tone];
---

<span
  class:list={[
    "inline-flex",
    "items-center",
    "gap-3",
    "text-xs",
    "font-medium",
    "uppercase",
    "tracking-[0.22em]",
    toneClass,
    className,
  ]}
>
  {line && <span class:list={["h-px", "w-8", "bg-current", "opacity-50"]} />}
  {bar && <span class:list={["w-4", "h-4", "bg-current", "rounded-xs"]} />}
  {text}
</span>
